# ── Hot—Pots Environment Variables ───────────────────────────
# Copy this file to .env and fill in your values.
# .env is in .gitignore and must NEVER be committed to git.

# ── Supabase ──────────────────────────────────────────────────
# Find these in: Supabase Dashboard → Project Settings → API

# Your project URL (safe to expose to client)
VITE_SUPABASE_URL=https://your-project-ref.supabase.co

# Anon/public key (safe to expose to client — RLS protects your data)
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# ── Push Notifications (VAPID) ────────────────────────────────
# Generate both keys with: npx web-push generate-vapid-keys
# Run once and save both values here.

# Public key — safe to expose to client (used in usePWA.js)
VITE_VAPID_PUBLIC_KEY=your-vapid-public-key-here

# Private key — SERVER SIDE ONLY. Never prefix with VITE_.
# Used only in the push-notify Supabase Edge Function.
# Add this to Supabase Dashboard → Edge Functions → Secrets, NOT here.
VAPID_PRIVATE_KEY=your-vapid-private-key-here

# Contact email for VAPID (used in push-notify Edge Function)
VAPID_CONTACT=mailto:admin@yourstudio.com

# ── Webhook Security ──────────────────────────────────────────
# A secret string used to verify that webhook calls to push-notify
# actually come from Supabase. Set this to any random string.
# Generate one with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# Add to Supabase Dashboard → Edge Functions → Secrets AND to the
# webhook configuration in Dashboard → Database → Webhooks.
WEBHOOK_SECRET=your-webhook-secret-here
